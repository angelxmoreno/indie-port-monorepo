{
    "name": "@indieport/database",
    "version": "0.0.0",
    "private": true,
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "scripts": {
        "build": "tsc",
        "type:check": "tsc --noEmit",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "db:generate": "drizzle-kit generate",
        "db:push": "drizzle-kit push",
        "db:migrate": "drizzle-kit migrate",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "test:coverage": "bun test --coverage"
    },
    "dependencies": {
        "@indieport/shared-types": "workspace:*",
        "drizzle-orm": "^0.41.0",
        "postgres": "^3.4.0"
    },
    "devDependencies": {
        "@types/bun": "^1.3.12",
        "drizzle-kit": "^0.30.0",
        "typescript": "^5.8.0"
    }
}
