{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", ".next/**", ".astro/**"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "type:check": {
            "dependsOn": ["^build"]
        },
        "db:generate": {
            "cache": false
        },
        "db:push": {
            "cache": false
        },
        "db:migrate": {
            "cache": false
        },
        "test": {
            "cache": false
        },
        "test:coverage": {
            "cache": false
        }
    }
}
