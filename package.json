{
    "name": "indieport",
    "packageManager": "bun@1.3.0",
    "private": true,
    "engines": {
        "node": ">=22",
        "bun": ">=1.3"
    },
    "scripts": {
        "prepare": "lefthook install",
        "build": "turbo build",
        "dev": "turbo dev",
        "type:check": "turbo type:check",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "clean": "./scripts/clean",
        "test": "turbo run test",
        "test:watch": "turbo run test:watch",
        "test:coverage": "turbo run test:coverage",
        "validate": "turbo run validate",
        "dup:jsinspect:cross": "jsinspect -t 50 --ignore \"node_modules|dist|docs|tests|coverage\" ./packages/*/src ./apps/*/src",
        "dup:jscpd:cross": "jscpd --config ./jscpd.json ./packages/*/src ./apps/*/src",
        "dup:jsinspect:staged": "bash -lc 'files=$(git diff --cached --name-only --diff-filter=ACM -- \"*.ts\" \"*.tsx\" \"*.js\" \"*.jsx\"); if [ -z \"$files\" ]; then exit 0; fi; jsinspect -t 50 --ignore \"node_modules|dist|docs|tests\" $files'",
        "dup:jscpd:staged": "bash -lc 'files=$(git diff --cached --name-only --diff-filter=ACM -- \"*.ts\" \"*.tsx\" \"*.js\" \"*.jsx\"); if [ -z \"$files\" ]; then exit 0; fi; jscpd --config ./jscpd.json $files'",
        "db:generate": "turbo db:generate",
        "db:push": "turbo db:push",
        "db:migrate": "turbo db:migrate"
    },
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "devDependencies": {
        "@biomejs/biome": "^2.4.13",
        "@commitlint/cli": "^20.5.2",
        "@commitlint/config-conventional": "^20.5.0",
        "@types/bun": "^1.3.13",
        "@types/node": "^25.6.0",
        "jscpd": "^4.0.9",
        "jsinspect-plus": "^3.1.3",
        "lefthook": "^2.1.6",
        "rimraf": "^6.1.3",
        "turbo": "^2.9.6",
        "typescript": "^6.0.3"
    }
}
