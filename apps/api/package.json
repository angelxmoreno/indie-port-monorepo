{
    "name": "@indieport/api",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "dev": "bun run --watch src/index.ts",
        "build": "bun build src/index.ts --outdir dist --target bun",
        "start": "bun run dist/index.js",
        "type:check": "tsc --noEmit",
        "test": "bun test",
        "test:coverage": "bun test --coverage"
    },
    "dependencies": {
        "@indieport/database": "workspace:*",
        "@indieport/shared-be": "workspace:*",
        "@indieport/shared-types": "workspace:*",
        "hono": "^4.7.0",
        "@hono/node-server": "^1.14.0"
    },
    "devDependencies": {
        "typescript": "^5.8.0",
        "@types/bun": "^1.2.0"
    }
}
